# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — required for real embeddings (text-embedding-3-small, 1536 dims)
OPENAI_API_KEY=your-openai-key

# Embedding fallback — set to "true" to allow placeholder embeddings when OpenAI fails.
# Fallback notes are marked with embedding_fallback:true in metadata.
# Keep false (default) in production: fallback notes produce unreliable semantic retrieval.
ALLOW_EMBEDDING_FALLBACK=false
